# Scotti indexer configuration. Copy to .env (gitignored) and edit, or export in
# the shell. Every value has a sensible default — the indexer runs with none set.

# Devnet RPC. Public works but is rate-limited; a dedicated endpoint is smoother.
RPC_URL=https://api.devnet.solana.com

# The House program. Defaults to the deployed devnet id from the repo.
PROGRAM_ID=EewsDJqfDEEfF8mKhQRED6NSB987LhkKL9wawjM7SBQ

# Polling interval for the ingest loop, in seconds (share-price sampling cadence).
INTERVAL=60

# SQLite file. Created on first run. Kept out of git.
DB_PATH=./scotti-indexer.db

# HTTP API port.
PORT=8787
