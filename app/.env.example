# Solana devnet RPC endpoint. The public endpoint works but is rate-limited;
# a free Helius/QuickNode/Triton devnet URL is smoother. NEVER commit your .env.
VITE_RPC_URL=https://api.devnet.solana.com

# OPTIONAL. Base URL of a running Scotti indexer (see ../indexer). When set, the
# LP dashboard shows a trailing share-price chart and machine pages show a recent-
# spins feed — clearly marked as off-chain, recompute-checked data. When unset or
# unreachable, the app degrades to chain-reads only (identical to shipping without
# it): the history stays honestly deferred.
# VITE_INDEXER_URL=http://localhost:8787
