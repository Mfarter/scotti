# Copy this file to `.env.local` (gitignored) and put your own devnet RPC endpoint
# below. The public endpoint (api.devnet.solana.com) works but rate-limits
# getProgramAccounts, so the Floor/Liquidity pools intermittently show
# "RPC rate-limited — retrying". A private devnet endpoint fixes it.
#
# Get a free devnet URL from Helius (https://dashboard.helius.dev), QuickNode, or
# Triton and paste it here. IMPORTANT: VITE_* vars are baked into the client bundle
# at build time and would ship in the public JS — treat the URL as public and use a
# devnet-only key you can rotate. NEVER commit .env.local or a real key to the repo.
VITE_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_DEVNET_KEY_HERE

# OPTIONAL. Base URL of a running Scotti indexer (see ../indexer). Unset ⇒ the app
# is chain-reads only and the trailing history stays honestly deferred.
# VITE_INDEXER_URL=http://localhost:8787
